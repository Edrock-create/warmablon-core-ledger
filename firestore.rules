rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == 'edgermulenga@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Rules
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) && 
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['viewer', 'contributor', 'admin'];
    }

    match /users/{userId} {
      allow get: if isVerified();
      allow list: if isAdmin();
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'viewer';
      allow update: if isVerified() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastActive', 'updatedAt'])) ||
        isAdmin()
      );
    }

    // 2. Session Rules
    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'action', 'status', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.action is string && data.action.size() <= 256 &&
             data.status is string && data.status.size() <= 64;
    }

    match /sessions/{sessionId} {
      allow read: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidSession(incoming());
    }
  }
}
